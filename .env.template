# =====================
# 应用配置 (app.config)
# =====================
APP_ENV=local
APP_PORT=3000
APP_HOST=0.0.0.0
APP_NAME=nest-admin
APP_VERSION=1.0.0
APP_LOG_LEVEL=info
APP_FRONTEND_URL=http://localhost:5173

# =====================
# 数据库 (database.config)
# =====================
DATABASE_URL="mysql://user:password@localhost:3306/nest_admin"

# 可选：数据库连接重试
# DB_CONNECT_RETRY_ATTEMPTS=5
# DB_CONNECT_RETRY_DELAY_MS=3000

# =====================
# Redis (redis.config)
# =====================
REDIS_URL=redis://localhost:6379
# 若使用 TLS: rediss://localhost:6379

# =====================
# 认证 (auth.config)
# =====================
AUTH_ACCESS_TOKEN_SECRET=your-access-token-secret-change-in-production
AUTH_ACCESS_TOKEN_EXP=15m
AUTH_REFRESH_TOKEN_TTL=604800
AUTH_MAGIC_LOGIN_TOKEN_TTL=300

# =====================
# 邮件 SMTP (email.config)
# =====================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# 可选：邮件发送限流
# EMAIL_RATE_LIMIT_MAX=1
# EMAIL_RATE_LIMIT_WINDOW=60
